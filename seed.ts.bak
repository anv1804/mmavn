import { createClient } from "@supabase/supabase-js";
import fs from "fs";
import path from "path";
import { fileURLToPath } from "url";

// Imports of local data
import { mmaClubs } from "../data/clubs.js";
import { leVanTuan } from "../data/fighters/le-van-tuan.js";

import { nam_52 } from "../data/rankings/nam_52.js";
import { nam_56 } from "../data/rankings/nam_56.js";
import { nam_60 } from "../data/rankings/nam_60.js";
import { nam_65 } from "../data/rankings/nam_65.js";
import { nam_70 } from "../data/rankings/nam_70.js";
import { nam_77 } from "../data/rankings/nam_77.js";
import { nu_48 } from "../data/rankings/nu_48.js";
import { nu_52 } from "../data/rankings/nu_52.js";

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

// Read .env file manually
const envPath = path.resolve(__dirname, "../../.env");
if (!fs.existsSync(envPath)) {
  console.error("No .env file found at " + envPath);
  process.exit(1);
}

const envContent = fs.readFileSync(envPath, "utf-8");
const envVars: Record<string, string> = {};
envContent.split("\n").forEach((line) => {
  const match = line.match(/^\s*([\w.-]+)\s*=\s*(.*)?\s*$/);
  if (match) {
    const key = match[1];
    let val = match[2] || "";
    // Remove quotes if present
    if (val.length > 0 && val.charAt(0) === '"' && val.charAt(val.length - 1) === '"') {
      val = val.substring(1, val.length - 1);
    }
    if (val.length > 0 && val.charAt(0) === "'" && val.charAt(val.length - 1) === "'") {
      val = val.substring(1, val.length - 1);
    }
    envVars[key] = val;
  }
});

const supabaseUrl = envVars["VITE_SUPABASE_URL"];
const supabaseKey = envVars["VITE_SUPABASE_PUBLISHABLE_KEY"];

if (!supabaseUrl || !supabaseKey) {
  console.error("Missing Supabase credentials in .env file");
  process.exit(1);
}

console.log("Connecting to Supabase at: " + supabaseUrl);
const supabase = createClient(supabaseUrl, supabaseKey);

async function runSeed() {
  console.log("--- SEEDING CLUBS ---");
  for (const club of mmaClubs) {
    const { error } = await supabase.from("clubs").upsert({
      id: club.id,
      slug: club.slug,
      name: club.name,
      short_name: club.shortName,
      english_name: club.englishName,
      city: club.city,
      district: club.district,
      address: club.address,
      region: club.region,
      founded_year: club.foundedYear,
      logo: club.logo,
      cover: club.cover,
      website: club.website,
      facebook: club.facebook,
      youtube: club.youtube,
      instagram: club.instagram,
      tiktok: club.tiktok,
      head_coach: club.headCoach,
      assistant_coaches: club.assistantCoaches,
      description: club.description,
      disciplines: club.disciplines,
      achievements: club.achievements,
      competitions: club.competitions,
      statistics: club.statistics,
      active: club.active,
      updated_at: club.updatedAt
    });

    if (error) {
      console.error(`Failed to seed club ${club.name}:`, error.message);
    } else {
      console.log(`Successfully seeded club: ${club.name}`);
    }
  }

  console.log("\n--- SEEDING FIGHTERS ---");
  // We seed Lê Văn Tuần profile
  const { error: fErr } = await supabase.from("fighters").upsert({
    id: leVanTuan.id,
    name: leVanTuan.name,
    nickname: leVanTuan.nickname,
    weight_class: leVanTuan.weightClass,
    club: leVanTuan.club,
    coach: leVanTuan.coach,
    photo: leVanTuan.photo,
    bio: leVanTuan.bio,
    birth_year: leVanTuan.birthYear,
    age: leVanTuan.age,
    height: leVanTuan.height,
    reach: leVanTuan.reach,
    hometown: leVanTuan.hometown,
    nationality: leVanTuan.nationality,
    flag: leVanTuan.flag,
    wins: leVanTuan.record.wins,
    losses: leVanTuan.record.losses,
    draws: leVanTuan.record.draws,
    ko_wins: leVanTuan.koWins,
    sub_wins: leVanTuan.subWins,
    decision_wins: leVanTuan.decisionWins,
    social_media: leVanTuan.socialMedia,
    achievements: leVanTuan.achievements,
    fights: leVanTuan.fights,
    active: leVanTuan.active
  });

  if (fErr) {
    console.error(`Failed to seed fighter ${leVanTuan.name}:`, fErr.message);
  } else {
    console.log(`Successfully seeded fighter: ${leVanTuan.name}`);
  }

  console.log("\n--- SEEDING RANKINGS/DIVISIONS ---");
  const divisions = [
    { id: "nam_52", name: "Hạng 52kg Nam", gender: "nam", ...nam_52 },
    { id: "nam_56", name: "Hạng 56kg Nam", gender: "nam", ...nam_56 },
    { id: "nam_60", name: "Hạng 60kg Nam", gender: "nam", ...nam_60 },
    { id: "nam_65", name: "Hạng 65kg Nam", gender: "nam", ...nam_65 },
    { id: "nam_70", name: "Hạng 70kg Nam", gender: "nam", ...nam_70 },
    { id: "nam_77", name: "Hạng 77kg Nam", gender: "nam", ...nam_77 },
    { id: "nu_48",  name: "Hạng 48kg Nữ",  gender: "nu",  ...nu_48 },
    { id: "nu_52",  name: "Hạng 52kg Nữ",  gender: "nu",  ...nu_52 },
  ];

  for (const div of divisions) {
    const { error: rErr } = await supabase.from("rankings").upsert({
      id: div.id,
      name: div.name,
      weight_class: div.weightClass,
      gender: div.gender,
      description: div.description,
      champion: div.champion,
      rankings: div.rankings
    });

    if (rErr) {
      console.error(`Failed to seed division ${div.name}:`, rErr.message);
    } else {
      console.log(`Successfully seeded division rankings: ${div.name}`);
    }
  }

  console.log("\n--- SEEDING COMPLETED ---");
}

runSeed().catch((err) => {
  console.error("Fatal error seeding database:", err);
});
